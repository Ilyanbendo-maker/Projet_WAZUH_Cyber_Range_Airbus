#!/usr/bin/env python3
# -*- coding: utf-8 -*-
# Collecteur SOC (root, cron) : agrege quarantaine + bans des 3 agents -> JSON dans le volume n8n.
# n8n ne fait AUCUN SSH (noeud SSH KO ici) : tout le SSH est fait ici en bash. Fichiers lus par Code+fs cote n8n.
import subprocess, json, os, re, datetime, shlex, base64

OUT = "/var/lib/docker/volumes/n8n_data/_data/socview"
SSH = ["sshpass", "-p", "<MOT_DE_PASSE_SSH_A_CONFIGURER>", "ssh", "-o", "StrictHostKeyChecking=no",
       "-o", "ConnectTimeout=8", "-o", "BatchMode=no"]
U2 = "192.168.0.2"   # 001 Agent_ubuntu2
WIN = "192.168.0.3"  # 002 Agent_windows

def now(): return datetime.datetime.utcnow().strftime("%Y-%m-%dT%H:%M:%SZ")

def run(cmd, timeout=25):
    try:
        p = subprocess.run(cmd, capture_output=True, timeout=timeout, text=True, errors="replace")
        return p.stdout or ""
    except Exception:
        return ""

# ---- quarantaine : lit les .manifest ----
QCMD = r'''for m in /var/ossec/quarantine/*.manifest; do [ -e "$m" ] || continue; echo "FILE:$(basename "$m" .manifest)"; cat "$m"; echo; done'''
def parse_q(blob):
    res = []; cur = None
    for ln in blob.splitlines():
        if ln.startswith("FILE:"): cur = ln[5:].strip()
        elif ln.strip().startswith("{") and cur:
            try:
                m = json.loads(ln)
                res.append({"qfile": cur, "original_path": m.get("original_path"), "quarantined_at": m.get("quarantined_at")})
            except Exception: pass
            cur = None
    return res

# ---- bans : iptables -S INPUT, regles DROP par -s <ip> (hors tailscale/docker) ----
def parse_ipt(blob):
    out = []
    for ln in blob.splitlines():
        if "INPUT" in ln and "-j DROP" in ln and "-s " in ln:
            m = re.search(r"-s (\d+\.\d+\.\d+\.\d+)", ln)
            if m:
                ip = m.group(1)
                if ip.startswith("100.6") or ip.startswith("100.7") or ip.startswith("172.17.") or ip.startswith("172.18."):
                    continue  # exclut tailscale CGNAT + docker
                out.append({"ip": ip, "source": "iptables"})
    # dedup
    seen=set(); ded=[]
    for b in out:
        if b["ip"] not in seen: seen.add(b["ip"]); ded.append(b)
    return ded

def remote(ip, inner):
    # execute 'inner' en root sur l'hote linux distant
    return run(SSH + ["lade@"+ip, "echo <MOT_DE_PASSE_SSH_A_CONFIGURER> | sudo -S -p '' bash -c " + shlex.quote(inner)])

# 000 (manager, local root)
q000 = parse_q(run(["bash","-c",QCMD]))
b000 = parse_ipt(run(["bash","-c","iptables -S INPUT 2>/dev/null"]))
# 001 (ubuntu2)
q001 = parse_q(remote(U2, QCMD))
b001 = parse_ipt(remote(U2, "iptables -S INPUT 2>/dev/null"))
# 002 (win11) : pas de quarantaine ; bans best-effort via PowerShell (regles Wazuh AR)
b002 = []
ps = ("Get-NetFirewallRule -DisplayName 'SOAR-BAN-*' -ErrorAction SilentlyContinue | "
      "Get-NetFirewallAddressFilter | ForEach-Object { $_.RemoteAddress }")
# -EncodedCommand : cmd.exe (Windows) ne gere pas le quoting POSIX -> base64 UTF-16LE
w = run(SSH + ["lade@"+WIN, "powershell -NoProfile -EncodedCommand " + base64.b64encode(ps.encode("utf-16-le")).decode()], timeout=30)
for ln in w.splitlines():
    m = re.search(r"\d+\.\d+\.\d+\.\d+", ln)
    if m: b002.append({"ip": m.group(0), "source": "netsh"})

quarantine = {"generated_at": now(), "agents": {
    "000": {"name": "ubuntu (manager)", "supported": True, "items": q000},
    "001": {"name": "Agent_ubuntu2", "supported": True, "items": q001},
    "002": {"name": "Agent_windows", "supported": False, "items": [], "note": "agent Windows : pas de quarantine-file (detection seule)"},
}}
bans = {"generated_at": now(), "agents": {
    "000": {"name": "ubuntu (manager)", "banned_ips": b000, "source": "iptables (live)"},
    "001": {"name": "Agent_ubuntu2", "banned_ips": b001, "source": "iptables (live)"},
    "002": {"name": "Agent_windows", "banned_ips": b002, "source": "Windows Firewall netsh (best-effort)"},
}}

def atomic(path, obj):
    tmp = path + ".tmp"
    with open(tmp, "w", encoding="utf-8") as f: json.dump(obj, f, ensure_ascii=False)
    os.replace(tmp, path)

os.makedirs(OUT, exist_ok=True)
atomic(OUT + "/quarantine.json", quarantine)
atomic(OUT + "/bans.json", bans)
for fn in ("quarantine.json", "bans.json"):
    try: os.chown(OUT + "/" + fn, 1000, 1000); os.chmod(OUT + "/" + fn, 0o644)
    except Exception: pass
print("OK quarantine: 000=%d 001=%d 002=N/A | bans: 000=%d 001=%d 002=%d" % (len(q000), len(q001), len(b000), len(b001), len(b002)))
