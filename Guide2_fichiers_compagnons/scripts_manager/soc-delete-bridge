#!/usr/bin/env python3
# -*- coding: utf-8 -*-
# Pont d'action SOC (root, cote manager). Endpoints HTTP (token requis) :
#   POST /delete {token, agent, path}  -> supprime un fichier (000 local, 001/002 SSH)
#   POST /ban    {token, ip}           -> bannit une IP PUBLIQUE sur LES 3 AGENTS (000 local iptables, 001 SSH iptables, 002 SSH PowerShell)
#   POST /unban  {token, ip}           -> retire le ban sur les 3 agents
# Bans Linux = iptables -I INPUT -s <ip> -j DROP (lu par list_bans). Bans Windows = regle "SOAR-BAN-<ip>" (nom maitrise -> deban fiable).
import json, os, re, subprocess, shlex, datetime, base64, ipaddress, time
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

TOKEN = open("/etc/soc-delete.token").read().strip()
LOG = "/var/ossec/logs/soc-delete.log"
SSH = ["sshpass", "-p", "<MOT_DE_PASSE_SSH_A_CONFIGURER>", "ssh", "-o", "StrictHostKeyChecking=no", "-o", "ConnectTimeout=8"]
HOSTS = {"001": "192.168.0.2", "002": "192.168.0.3"}
# IP de l'infrastructure SOC : JAMAIS bannissables (les bannir couperait le manager ou un agent de son lien Wazuh)
INFRA = {"192.168.0.1", "192.168.0.2", "192.168.0.3",        # manager + agents (LAN)
         "100.73.179.63", "100.67.35.26",                     # manager + PC hote (tailnet)
         "100.101.128.76", "100.101.80.37"}                   # agents (tailnet)

DENY_LIN = ["/etc", "/bin", "/sbin", "/usr", "/lib", "/lib64", "/boot", "/sys", "/proc",
            "/dev", "/run", "/var/ossec/bin", "/var/ossec/active-response", "/var/ossec/etc",
            "/var/ossec/ruleset", "/root/.ssh", "/var/lib/docker"]
DENY_WIN = ["c:\\windows", "c:\\program files", "c:\\programdata\\ossec",
            "c:\\program files (x86)\\ossec-agent"]

def log(m):
    try:
        with open(LOG, "a") as f:
            f.write("%s %s\n" % (datetime.datetime.now().strftime("%Y/%m/%d %H:%M:%S"), m))
    except Exception:
        pass

def bad_chars(p):
    return bool(re.search(r"""[;&|`$\n\r<>*?"']""", p)) or ".." in p

# ---------- DELETE ----------
def check_linux(p):
    if not p.startswith("/") or bad_chars(p):
        return "chemin invalide"
    rp = os.path.normpath(p)
    if rp == "/" or rp.count("/") < 2:
        return "chemin trop haut (racine)"
    for d in DENY_LIN:
        if rp == d or rp.startswith(d + "/"):
            return "chemin systeme protege (%s)" % d
    return None

def check_win(p):
    if bad_chars(p.replace("\\", "/")) or not re.match(r"^[a-zA-Z]:\\", p):
        return "chemin Windows invalide"
    low = p.lower()
    for d in DENY_WIN:
        if low.startswith(d):
            return "chemin systeme protege (%s)" % d
    return None

def _psq(p):
    return "'" + p.replace("'", "''") + "'"

def _win_ps(ps, timeout=30):
    enc = base64.b64encode(ps.encode("utf-16-le")).decode()
    return subprocess.run(SSH + ["lade@" + HOSTS["002"], "powershell -NoProfile -EncodedCommand " + enc],
                          capture_output=True, text=True, errors="replace", timeout=timeout)

def do_delete(agent, path):
    if agent in ("000", "001"):
        err = check_linux(path)
        if err: return False, "REFUS: " + err
    elif agent == "002":
        err = check_win(path)
        if err: return False, "REFUS: " + err
    else:
        return False, "agent inconnu"
    if agent == "000":
        if not os.path.isfile(path): return False, "fichier introuvable sur le manager: " + path
        try: os.remove(path); return True, "supprime (manager): " + path
        except Exception as e: return False, "erreur: " + str(e)
    if agent == "001":
        cmd = SSH + ["lade@" + HOSTS["001"],
                     "echo <MOT_DE_PASSE_SSH_A_CONFIGURER> | sudo -S -p '' bash -c " + shlex.quote("test -f %s && rm -f -- %s && echo DELETED || echo NOTFOUND" % (shlex.quote(path), shlex.quote(path)))]
        r = subprocess.run(cmd, capture_output=True, text=True, errors="replace", timeout=25)
        return ("DELETED" in r.stdout), (("supprime (001): " + path) if "DELETED" in r.stdout else "echec/introuvable (001): " + (r.stdout + r.stderr)[:160])
    if agent == "002":
        ps = "if (Test-Path -LiteralPath %s) { Remove-Item -Force -LiteralPath %s; if (-not (Test-Path -LiteralPath %s)) { 'DELETED' } else { 'FAIL' } } else { 'NOTFOUND' }" % (_psq(path), _psq(path), _psq(path))
        r = _win_ps(ps)
        return ("DELETED" in r.stdout), (("supprime (002 win11): " + path) if "DELETED" in r.stdout else "echec/introuvable (002): " + (r.stdout + r.stderr).strip()[:160])

# ---------- BAN / UNBAN (les 3 agents) ----------
def _ipt_local(args):
    return subprocess.run(["iptables"] + args, capture_output=True, text=True, errors="replace", timeout=15)

def _ipt_ssh(host, args):
    inner = "iptables " + " ".join(shlex.quote(a) for a in args)
    return subprocess.run(SSH + ["lade@" + host, "echo <MOT_DE_PASSE_SSH_A_CONFIGURER> | sudo -S -p '' " + inner],
                          capture_output=True, text=True, errors="replace", timeout=25)

def _lin_ban(run_ipt, ip):
    if run_ipt(["-C", "INPUT", "-s", ip, "-j", "DROP"]).returncode != 0:
        run_ipt(["-I", "INPUT", "-s", ip, "-j", "DROP"])
    return run_ipt(["-C", "INPUT", "-s", ip, "-j", "DROP"]).returncode == 0

def _lin_unban(run_ipt, ip):
    n = 0
    while n < 20 and run_ipt(["-D", "INPUT", "-s", ip, "-j", "DROP"]).returncode == 0:
        n += 1
    return True

def do_ban(ip, undo=False):
    try:
        a = ipaddress.ip_address(ip)
    except Exception:
        return False, "REFUS: IP invalide"
    if a.version != 4:
        return False, "REFUS: seules les IPv4 sont gerees pour le ban"
    # garde-fou : on protege UNIQUEMENT l'infra SOC (le ban est sinon autorise : public, LAN, tailnet...)
    # Le déban (undo) n'est jamais bloque (retirer un ban est toujours sans risque).
    if not undo and ip in INFRA:
        return False, "REFUS: IP de l'infrastructure SOC (manager/agents) jamais bannissable"
    name = "SOAR-BAN-" + ip
    res = []
    # 000 (manager, local)
    try:
        (_lin_unban if undo else _lin_ban)(_ipt_local, ip); res.append("000:ok")
    except Exception as e:
        res.append("000:err(%s)" % e); log("ban000 KO: %s" % e)
    # 001 (ubuntu-2, SSH)
    try:
        (_lin_unban if undo else _lin_ban)(lambda a: _ipt_ssh(HOSTS["001"], a), ip); res.append("001:ok")
    except Exception as e:
        res.append("001:err"); log("ban001 KO: %s" % e)
    # 002 (win11, SSH PowerShell, regle nommee)
    try:
        if undo:
            ps = "Get-NetFirewallRule -DisplayName '%s' -ErrorAction SilentlyContinue | Remove-NetFirewallRule -ErrorAction SilentlyContinue; 'OK'" % name
        else:
            ps = ("if (-not (Get-NetFirewallRule -DisplayName '%s' -ErrorAction SilentlyContinue)) "
                  "{ New-NetFirewallRule -DisplayName '%s' -Direction Inbound -Action Block -RemoteAddress %s | Out-Null }; 'OK'" % (name, name, ip))
        r = _win_ps(ps)
        res.append("002:" + ("ok" if "OK" in r.stdout else "err"))
    except Exception as e:
        res.append("002:err"); log("ban002 KO: %s" % e)
    return True, ("unban" if undo else "ban") + " " + ip + " -> " + ", ".join(res)

def do_unban(ip):
    return do_ban(ip, undo=True)

# ---------- ISOLATE / UNISOLATE win11 (002) ----------
# Isolement Linux (001) = AR Wazuh (cote n8n). win11 = ici, via SSH + pare-feu Windows (les scripts .ps1 portent toute la logique anti-lockout).
WIN_PS_DIR = "/usr/local/share/soc"          # win11_isolate.ps1 / win11_unisolate.ps1 (cote manager)
WIN_DIR = "C:\\ProgramData\\SOAR"            # destination sur win11

SCP = ["sshpass", "-p", "<MOT_DE_PASSE_SSH_A_CONFIGURER>", "scp", "-o", "StrictHostKeyChecking=no", "-o", "ConnectTimeout=8"]

def _win_push_scripts():
    # cmd.exe limite la ligne a ~8191 car. -> copie inline EncodedCommand impossible (scripts trop gros). On passe par scp.
    res = []
    try:
        _win_ps("New-Item -ItemType Directory -Force -Path '%s' | Out-Null; 'OK'" % WIN_DIR)
    except Exception:
        pass
    for fn, dest in [("win11_isolate.ps1", "C:/ProgramData/SOAR/isolate.ps1"),
                     ("win11_unisolate.ps1", "C:/ProgramData/SOAR/unisolate.ps1")]:
        src = os.path.join(WIN_PS_DIR, fn)
        if not os.path.isfile(src):
            res.append(fn + ":readfail"); continue
        try:
            r = subprocess.run(SCP + [src, "lade@" + HOSTS["002"] + ":" + dest],
                               capture_output=True, text=True, errors="replace", timeout=30)
            res.append(fn + ":" + ("ok" if r.returncode == 0 else "err"))
        except Exception:
            res.append(fn + ":timeout")
    return res

def do_win_isolate():
    push = _win_push_scripts()
    if any(x.endswith(("readfail", "err", "timeout")) for x in push):
        return False, "win11: echec copie des scripts (" + ", ".join(push) + ")"
    # dead-man (auto-desisolement 15 min, SYSTEM, persiste au reboot) + isolement DETACHE en tache SYSTEM
    # dead-man ROBUSTE : fire a T+15min, mais StartWhenAvailable (rejoue si rate apres power-off) + repetition (retente)
    setup = (
        "$ErrorActionPreference='SilentlyContinue';"
        "$au=New-ScheduledTaskAction -Execute 'powershell.exe' -Argument '-NoProfile -ExecutionPolicy Bypass -File %s\\unisolate.ps1';"
        "$tg=New-ScheduledTaskTrigger -Once -At ((Get-Date).AddMinutes(15)) -RepetitionInterval (New-TimeSpan -Minutes 10) -RepetitionDuration (New-TimeSpan -Hours 6);"
        "$set=New-ScheduledTaskSettingsSet -StartWhenAvailable -AllowStartIfOnBatteries -DontStopIfGoingOnBatteries;"
        "Register-ScheduledTask -TaskName 'SOAR-DEADMAN' -Action $au -Trigger $tg -Settings $set -User 'SYSTEM' -RunLevel Highest -Force | Out-Null;"
        "$ai=New-ScheduledTaskAction -Execute 'powershell.exe' -Argument '-NoProfile -ExecutionPolicy Bypass -File %s\\isolate.ps1';"
        "Register-ScheduledTask -TaskName 'SOAR-ISOLATE-RUN' -Action $ai -User 'SYSTEM' -RunLevel Highest -Force | Out-Null;"
        "Start-ScheduledTask -TaskName 'SOAR-ISOLATE-RUN'; 'SETUP_OK'" % (WIN_DIR, WIN_DIR))
    try:
        r = _win_ps(setup)
    except Exception as e:
        return False, "win11: echec preparation isolement (timeout setup): " + str(e)
    if "SETUP_OK" not in r.stdout:
        return False, "win11: echec preparation isolement: " + (r.stdout + r.stderr).strip()[:160]
    # confirmation par RECONNEXION SSH (= preuve de joignabilite) + lecture du statut terminal
    status = None; reachable = False
    for _ in range(7):
        time.sleep(5)
        try:
            rr = _win_ps("Get-Content '%s\\isolate.status' -ErrorAction SilentlyContinue" % WIN_DIR, timeout=20)
        except Exception:
            continue  # injoignable pour l'instant
        if rr.returncode == 0:
            reachable = True
            s = rr.stdout.strip().splitlines()[-1].strip() if rr.stdout.strip() else ""
            if s in ("ISOLATED_OK", "ROLLBACK"):
                status = s; break
    if status == "ISOLATED_OK":
        _win_ps("schtasks /delete /tn 'SOAR-DEADMAN' /f 2>$null; schtasks /delete /tn 'SOAR-ISOLATE-RUN' /f 2>$null")
        return True, "win11 (002) ISOLE (Internet + LAN + Tailscale coupes). Joignable uniquement via le manager (Wazuh + SSH) ; reconnexion confirmee. (Service Tailscale laisse actif, se reconnecte au desisolement.)"
    if status == "ROLLBACK":
        _win_ps("schtasks /delete /tn 'SOAR-DEADMAN' /f 2>$null; schtasks /delete /tn 'SOAR-ISOLATE-RUN' /f 2>$null")
        return False, "win11 (002) : isolement ANNULE par auto-rollback (verif KO). Machine restee connectee."
    if reachable:
        return False, "win11 (002) joignable mais isolement NON confirme (statut non finalise). Dead-man garde (auto-desisolement ~15 min)."
    return False, "win11 (002) injoignable apres isolement (possible lockout). Dead-man actif : auto-desisolement dans ~15 min."

def do_win_unisolate():
    push = _win_push_scripts()
    ps = ("powershell -NoProfile -ExecutionPolicy Bypass -File '%s\\unisolate.ps1';"
          "schtasks /delete /tn 'SOAR-DEADMAN' /f 2>$null | Out-Null;"
          "schtasks /delete /tn 'SOAR-ISOLATE-RUN' /f 2>$null | Out-Null;"
          "Get-Content '%s\\isolate.status' -ErrorAction SilentlyContinue" % (WIN_DIR, WIN_DIR))
    try:
        r = _win_ps(ps, timeout=70)
    except Exception as e:
        return False, "win11: timeout desisolement: " + str(e)
    ok = "UNISOLATED_OK" in r.stdout
    return ok, ("win11 (002) DESISOLE (pare-feu restaure OFF, acces reseau complet retabli)." if ok
                else "win11: echec desisolement: " + (r.stdout + r.stderr).strip()[:160])

class H(BaseHTTPRequestHandler):
    def log_message(self, *a): pass
    def _send(self, code, obj):
        b = json.dumps(obj).encode()
        self.send_response(code); self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(b))); self.end_headers(); self.wfile.write(b)
    def do_POST(self):
        try:
            n = int(self.headers.get("Content-Length", 0)); d = json.loads(self.rfile.read(n).decode())
        except Exception:
            return self._send(400, {"ok": False, "message": "bad json"})
        if d.get("token") != TOKEN:
            log("AUTH KO depuis %s" % self.client_address[0]); return self._send(401, {"ok": False, "message": "unauthorized"})
        try:
            if self.path == "/delete":
                ok, msg = do_delete(str(d.get("agent", "")).strip(), str(d.get("path", "")).strip())
            elif self.path == "/ban":
                ok, msg = do_ban(str(d.get("ip", "")).strip())
            elif self.path == "/unban":
                ok, msg = do_unban(str(d.get("ip", "")).strip())
            elif self.path == "/isolate":
                if str(d.get("agent", "")).strip() != "002":
                    return self._send(200, {"ok": False, "message": "pont isolate = win11 (002) uniquement (001 via AR Wazuh)"})
                ok, msg = do_win_isolate()
            elif self.path == "/unisolate":
                if str(d.get("agent", "")).strip() != "002":
                    return self._send(200, {"ok": False, "message": "pont unisolate = win11 (002) uniquement"})
                ok, msg = do_win_unisolate()
            else:
                return self._send(404, {"ok": False, "message": "not found"})
        except Exception as e:
            ok, msg = False, "erreur interne: " + str(e)
        log("%s -> %s" % (self.path, msg))
        return self._send(200, {"ok": ok, "message": msg})

if __name__ == "__main__":
    ThreadingHTTPServer(("172.17.0.1", 5601), H).serve_forever()
