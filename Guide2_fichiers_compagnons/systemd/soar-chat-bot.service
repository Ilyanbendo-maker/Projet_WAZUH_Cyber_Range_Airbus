[Unit]
Description=SOAR Discord chat-IA bot
After=network-online.target
Wants=network-online.target

[Service]
User=lade
WorkingDirectory=/home/lade/soar-bot
EnvironmentFile=/home/lade/soar-bot/chat_config.env
ExecStart=/home/lade/soar-bot/venv/bin/python /home/lade/soar-bot/soar_chat_bot.py
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
