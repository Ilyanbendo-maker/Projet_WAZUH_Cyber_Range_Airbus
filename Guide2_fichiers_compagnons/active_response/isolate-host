#!/usr/bin/python3
# -*- coding: utf-8 -*-
# Active-response ISOLATE-HOST : isole l'hote des 2 reseaux (LAN + tailscale) + Internet, IPv4 ET IPv6,
# en preservant le canal Wazuh (LAN 192.168.0.1). Application ATOMIQUE (iptables-restore -w),
# sentinelle d'etat + verrou (idempotent), GARDE-FOU anti-lockout (rollback si le canal manager manque).
#   add -> isole (no-op si deja isole). delete -> restaure (no-op si non isole).
# NOTE TAILSCALE : on ne touche PAS a tailscale. Couper tout l'egress sauf le manager bloque le transport
# WireGuard (UDP vers DERP/pairs) -> le tailnet est mort de toute facon ; et il se reconnecte SEUL au restore.
import json, os, sys, select, subprocess, fcntl, time

os.environ["PATH"] = "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:" + os.environ.get("PATH", "")
MANAGER_IP = "192.168.0.1"            # canal Wazuh (LAN, IP statique). Seule exception a l'isolement.
WAZUH_PORTS = ["1514", "1515", "55000"]
B4 = "/var/ossec/tmp/iptables_pre_isolation.backup"
B6 = "/var/ossec/tmp/ip6tables_pre_isolation.backup"
FLAG = "/var/ossec/tmp/isolation.active"
LOCK = "/var/ossec/tmp/isolation.lock"
LOG = "/var/ossec/logs/active-responses.log"

def log(m):
    try:
        with open(LOG, "a") as f:
            f.write("%s isolate-host: %s\n" % (time.strftime("%Y/%m/%d %H:%M:%S"), m))
    except Exception:
        pass

def run(cmd, **k):
    try:
        return subprocess.run(cmd, **k)
    except Exception as e:
        log("ERR %s: %s" % (" ".join(cmd[:2]), e))
        return None

def _read_ar():
    buf = b""
    while True:
        r, _, _ = select.select([0], [], [], 3.0)
        if not r:
            break
        c = os.read(0, 65536)
        if not c:
            break
        buf += c
        try:
            return json.loads(buf.decode(errors="replace"))
        except Exception:
            pass
    try:
        return json.loads(buf.decode(errors="replace"))
    except Exception:
        return {}

def v4_ruleset():
    L = ["*filter", ":INPUT DROP [0:0]", ":FORWARD DROP [0:0]", ":OUTPUT DROP [0:0]",
         "-A INPUT -i lo -j ACCEPT", "-A OUTPUT -o lo -j ACCEPT"]
    for p in WAZUH_PORTS:
        L.append("-A OUTPUT -d %s -p tcp --dport %s -j ACCEPT" % (MANAGER_IP, p))
        L.append("-A INPUT -s %s -p tcp --sport %s -j ACCEPT" % (MANAGER_IP, p))
    L.append("-A INPUT -s %s -m state --state ESTABLISHED,RELATED -j ACCEPT" % MANAGER_IP)
    L.append("-A OUTPUT -d %s -m state --state ESTABLISHED,RELATED -j ACCEPT" % MANAGER_IP)
    L.append("COMMIT")
    return "\n".join(L) + "\n"

def v6_ruleset():
    return ("*filter\n:INPUT DROP [0:0]\n:FORWARD DROP [0:0]\n:OUTPUT DROP [0:0]\n"
            "-A INPUT -i lo -j ACCEPT\n-A OUTPUT -o lo -j ACCEPT\nCOMMIT\n")

def restore_backup():
    ok = True
    if os.path.exists(B4):
        with open(B4) as f:
            r = run(["iptables-restore", "-w", "5"], stdin=f)
        ok = ok and r is not None and r.returncode == 0
    if os.path.exists(B6):
        with open(B6) as f:
            r = run(["ip6tables-restore", "-w", "5"], stdin=f)
        ok = ok and r is not None and r.returncode == 0
    return ok

def do_isolate():
    if os.path.exists(FLAG):
        log("deja isole, no-op"); return
    for save, B in (("iptables-save", B4), ("ip6tables-save", B6)):
        tmp = B + ".tmp"
        with open(tmp, "w") as f:
            r = run([save], stdout=f)
        if r is None or r.returncode != 0 or os.path.getsize(tmp) == 0:
            log("backup %s invalide -> abandon (jamais de DROP sans filet)" % save)
            try: os.remove(tmp)
            except Exception: pass
            return
        os.replace(tmp, B)
    r4 = run(["iptables-restore", "-w", "5"], input=v4_ruleset(), text=True)
    r6 = run(["ip6tables-restore", "-w", "5"], input=v6_ruleset(), text=True)
    chk = run(["iptables", "-w", "5", "-C", "OUTPUT", "-d", MANAGER_IP, "-p", "tcp", "--dport", "1514", "-j", "ACCEPT"])
    if r4 is None or r4.returncode != 0 or chk is None or chk.returncode != 0:
        log("isolement v4 KO ou regle manager absente -> ROLLBACK")
        restore_backup()
        try:
            os.remove(B4); os.remove(B6)
        except Exception: pass
        return
    if r6 is None or r6.returncode != 0:
        log("ATTENTION isolement IPv6 KO (v4 OK, canal OK) -> IPv6 peut fuiter")
    open(FLAG, "w").write(time.strftime("%Y-%m-%dT%H:%M:%S"))
    log("isole OK (LAN+tailscale+Internet coupes, IPv4%s ; tailscale tombe via blocage egress)" %
        ("+IPv6" if (r6 and r6.returncode == 0) else " ; IPv6 partiel"))

def do_restore():
    if not os.path.exists(FLAG) and not os.path.exists(B4):
        log("non isole, no-op"); return
    ok = restore_backup()
    if ok:
        for p in (B4, B6, FLAG):
            try: os.remove(p)
            except Exception: pass
        log("desisole OK (tailscale se reconnecte seul)")
    else:
        log("echec restore -> backup CONSERVE pour re-essai (reboot = filet ultime)")

def main():
    os.makedirs("/var/ossec/tmp", exist_ok=True)
    lk = open(LOCK, "w")
    fcntl.flock(lk, fcntl.LOCK_EX)
    data = _read_ar()
    command = data.get("command")
    log("command=%s (deja isole=%s)" % (command, os.path.exists(FLAG)))
    if command == "add":
        do_isolate()
    elif command == "delete":
        do_restore()

main()
