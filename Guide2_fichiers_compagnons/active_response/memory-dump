#!/usr/bin/env python3
import sys, json, os, select, subprocess, shutil, ipaddress, datetime
os.environ["PATH"] = "/usr/sbin:/usr/bin:/sbin:/bin:" + os.environ.get("PATH", "")

def _read_ar():
    """Lit le message AR Wazuh sans bloquer (execd garde le pipe ouvert: pas d'EOF)."""
    buf = b""
    while True:
        r, _, _ = select.select([0], [], [], 3.0)
        if not r:
            break
        c = os.read(0, 65536)
        if not c:
            break
        buf += c
        try:
            return json.loads(buf.decode(errors="replace"))
        except Exception:
            pass
    return json.loads(buf.decode(errors="replace"))

data = _read_ar()
command = data.get("command")
extra = data.get("parameters", {}).get("extra_args", [])
alert = data.get("parameters", {}).get("alert", {})

DUMP_DIR = "/var/ossec/forensics/memory"
if command == "add":
    os.makedirs(DUMP_DIR, exist_ok=True)
    ts = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
    df = f"{DUMP_DIR}/{os.uname().nodename}_{ts}.lime"
    if os.path.exists("/usr/local/bin/avml"):
        subprocess.run(["/usr/local/bin/avml", df], timeout=300)
    else:
        shutil.copy2("/proc/kcore", df)
