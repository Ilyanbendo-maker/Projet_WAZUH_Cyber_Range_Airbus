#!/usr/bin/env python3
import sys, json, os, select, subprocess, shutil, ipaddress, datetime
os.environ["PATH"] = "/usr/sbin:/usr/bin:/sbin:/bin:" + os.environ.get("PATH", "")

def _read_ar():
    """Lit le message AR Wazuh sans bloquer (execd garde le pipe ouvert: pas d'EOF)."""
    buf = b""
    while True:
        r, _, _ = select.select([0], [], [], 3.0)
        if not r:
            break
        c = os.read(0, 65536)
        if not c:
            break
        buf += c
        try:
            return json.loads(buf.decode(errors="replace"))
        except Exception:
            pass
    return json.loads(buf.decode(errors="replace"))

data = _read_ar()
command = data.get("command")
extra = data.get("parameters", {}).get("extra_args", [])
alert = data.get("parameters", {}).get("alert", {})

fp = alert.get("syscheck", {}).get("path", "") or (extra[0] if extra else "")
BACKUP_DIR = "/var/ossec/backup/critical-files"
CORRUPTED_DIR = "/var/ossec/backup/corrupted"
CRITICAL_FILES = ["/etc/sudoers", "/etc/passwd", "/etc/shadow", "/etc/group",
                  "/etc/ssh/sshd_config", "/etc/hosts.allow", "/etc/hosts.deny", "/etc/crontab"]
if command == "add" and fp in CRITICAL_FILES:
    name = fp.replace("/", "_").lstrip("_")
    bpath = f"{BACKUP_DIR}/{name}"
    if os.path.exists(bpath):
        os.makedirs(CORRUPTED_DIR, exist_ok=True)
        ts = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        shutil.copy2(fp, f"{CORRUPTED_DIR}/{ts}_{name}")
        shutil.copy2(bpath, fp)
        os.chmod(fp, 0o440 if fp == "/etc/sudoers" else 0o640 if fp == "/etc/shadow" else 0o644)
