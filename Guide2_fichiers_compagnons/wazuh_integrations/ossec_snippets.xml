<!-- Extraits a placer dans /var/ossec/etc/ossec.conf du MANAGER. Remplacer <VOTRE_CLE_...> par vos cles. -->

<!-- ===== INTEGRATIONS : enrichissement + envoi vers n8n ===== -->
  <integration>
    <name>virustotal</name>
    <api_key><VOTRE_CLE_API></api_key>
    <rule_id>550,554,750,594</rule_id>
    <alert_format>json</alert_format>
  </integration>
  <integration>
  <name>custom-deepseek</name>
    <api_key><VOTRE_CLE_API></api_key>
    <alert_format>json</alert_format>
    <level>7</level>
  </integration>
  <integration>
    <name>shuffle</name>
    <hook_url>http://localhost:5678/webhook/wazuh</hook_url>
    <level>8</level>
    <alert_format>json</alert_format>
  </integration>
  <integration>
    <name>shuffle</name>
    <hook_url>http://localhost:5678/webhook/wazuh-soar-validate</hook_url>
    <level>10</level>
    <alert_format>json</alert_format>
  </integration>

