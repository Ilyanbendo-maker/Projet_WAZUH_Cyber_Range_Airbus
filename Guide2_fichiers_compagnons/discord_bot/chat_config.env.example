# Bot chat-IA (#chat-ia). A copier en chat_config.env, puis remplir.
CHAT_BOT_TOKEN=<VOTRE_TOKEN_BOT_CHAT>
CHAT_CHANNEL_ID=<ID_DU_SALON_CHAT_IA>
# URL du webhook chat de l'agent (workflow SOC Assistant). L hote est reecrit vers 127.0.0.1 par le bot.
N8N_CHAT_URL=http://127.0.0.1:5678/webhook/<ID_WEBHOOK_CHAT>/chat
